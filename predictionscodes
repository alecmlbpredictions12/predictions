const Hashids = require('hashids');
const { randomUUID } = require('crypto');

const API_BASE_URL = 'https://web.realsports.io';
const HASHIDS_SALT = 'realwebapp';
const HASHIDS_MIN_LENGTH = 16;
const DEVICE_TYPE = 'desktop_web';
const REAL_VERSION = '27';
const VALID_SPORTS = ['nba', 'wnba', 'mlb', 'nhl', 'nfl', 'ncaam', 'soccer'];

const hashids = new Hashids(HASHIDS_SALT, HASHIDS_MIN_LENGTH);
// Persists for the life of a warm serverless instance, mirroring the
// python script's one-uuid-per-run behavior closely enough for this use.
const SESSION_DEVICE_UUID = randomUUID();

function generateRequestToken() {
  return hashids.encode(Date.now());
}

function getHeaders(authInfo) {
  return {
    accept: 'application/json',
    'content-type': 'application/json',
    origin: 'https://realsports.io',
    referer: 'https://realsports.io/',
    'real-auth-info': authInfo,
    'real-device-type': DEVICE_TYPE,
    'real-device-uuid': SESSION_DEVICE_UUID,
    'real-request-token': generateRequestToken(),
    'real-version': REAL_VERSION,
  };
}

async function apiGet(path, authInfo, params = {}, timeoutMs = 15000) {
  const url = new URL(API_BASE_URL + path);
  Object.entries(params).forEach(([k, v]) => {
    if (v !== undefined && v !== null) url.searchParams.set(k, String(v));
  });
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), timeoutMs);
  try {
    const res = await fetch(url.toString(), { headers: getHeaders(authInfo), signal: controller.signal });
    if (!res.ok) {
      const err = new Error(`HTTP ${res.status} for ${path}`);
      err.status = res.status;
      throw err;
    }
    return await res.json();
  } finally {
    clearTimeout(timer);
  }
}

function normalizeDay(value) {
  if (!/^\d{4}-\d{2}-\d{2}$/.test(String(value || ''))) {
    throw new Error(`Invalid date (expected YYYY-MM-DD): ${value}`);
  }
  return value;
}

async function resolveUserId(username, authInfo) {
  const handle = username.replace(/^@/, '').trim();
  const payload = await apiGet(`/user/${handle}`, authInfo);
  const userId = payload && payload.user && payload.user.id;
  if (!userId) throw new Error(`Could not resolve @${handle}`);
  return String(userId);
}

async function fetchHomeContests(sport, authInfo) {
  const payload = await apiGet(`/home/${sport}/next`, authInfo, { cohort: 0 });
  return (
    (payload &&
      payload.latestDayContent &&
      payload.latestDayContent.config &&
      payload.latestDayContent.config.dailyDraftInfo &&
      payload.latestDayContent.config.dailyDraftInfo.contests) ||
    []
  );
}

function contestMatches(contest, sport, contestDay) {
  return (
    contest &&
    contest.id != null &&
    String(contest.sport || '').toLowerCase() === sport &&
    String(contest.day || '') === contestDay &&
    contest.gameId == null
  );
}

async function fetchContestMetadata(contestId, authInfo, contestType) {
  try {
    const payload = await apiGet(
      `/games/playerratingcontest/${contestId}/entries`,
      authInfo,
      { contestType, isGuillotine: 'false', limit: 1 },
      12000
    );
    return (payload && payload.contest) || null;
  } catch {
    return null;
  }
}

async function mapWithConcurrency(items, limit, fn) {
  const results = new Array(items.length);
  let idx = 0;
  async function worker() {
    while (idx < items.length) {
      const current = idx++;
      results[current] = await fn(items[current], current);
    }
  }
  const workerCount = Math.max(1, Math.min(limit, items.length));
  await Promise.all(Array.from({ length: workerCount }, worker));
  return results;
}

async function findContestId(sport, contestDay, authInfo, contestType = 'sport', scanLimit = 300) {
  sport = sport.trim().toLowerCase();
  contestDay = normalizeDay(contestDay);
  const homeContests = await fetchHomeContests(sport, authInfo);

  const candidateIds = [];
  for (const contest of homeContests) {
    if (contest && contest.id != null) candidateIds.push(Number(contest.id));
    if (contestMatches(contest, sport, contestDay)) return Number(contest.id);
  }
  if (candidateIds.length === 0) {
    throw new Error(`Could not find a current Draft contest anchor for ${sport}`);
  }

  const anchorId = candidateIds[0];
  const forwardWindow = Math.min(50, Math.max(0, Math.floor(scanLimit / 6)));
  const scanIds = [anchorId];
  const backStop = Math.max(0, anchorId - scanLimit);
  for (let i = anchorId - 1; i > backStop; i--) scanIds.push(i);
  for (let i = anchorId + 1; i <= anchorId + forwardWindow; i++) scanIds.push(i);
  const uniqueIds = [...new Set(scanIds)];

  const metas = await mapWithConcurrency(uniqueIds, 12, (id) =>
    fetchContestMetadata(id, authInfo, contestType)
  );
  const matches = metas.filter((m) => contestMatches(m, sport, contestDay));
  if (matches.length > 0) {
    matches.sort((a, b) => Number(b.id) - Number(a.id));
    return Number(matches[0].id);
  }
  throw new Error(`Could not find a ${sport} Draft contest for ${contestDay}`);
}

async function fetchLineup(contestId, userId, authInfo, contestType) {
  return apiGet(`/games/playerratingcontest/${contestId}/view/${userId}`, authInfo, { contestType });
}

function asFloat(value) {
  if (value === null || value === undefined) return null;
  const n = Number(value);
  return Number.isNaN(n) ? null : n;
}

function summarizeLineup(username, payload) {
  const info = (payload && payload.info) || {};
  const contest = info.contest || {};
  const user = info.user || {};
  const lineup = payload.lineup || [];
  const total = lineup.reduce((sum, p) => sum + (asFloat(p.score) || 0), 0);

  const summary = {
    inputUsername: username,
    userName: user.userName,
    userId: info.userId,
    contestId: contest.id,
    sport: contest.sport,
    day: contest.day,
    scoreDisplay: info.scoreDisplay,
    rankDisplay: info.rankDisplay,
    calculatedScore: Math.round(total * 100) / 100,
    isFinalized: contest.isFinalized,
  };

  const players = [...lineup]
    .sort((a, b) => (a.order || 0) - (b.order || 0))
    .map((p) => ({
      inputUsername: username,
      userName: user.userName,
      order: p.order,
      playerId: p.playerId || p.id,
      player: p.displayName,
      realRank: p.realRank,
      value: asFloat(p.value),
      multiplier: asFloat(p.multiplier),
      multiplierDisplay: p.multiplierDisplay,
      score: asFloat(p.score),
    }));

  return { summary, players };
}

module.exports = async function handler(req, res) {
  if (req.method !== 'POST') {
    res.status(405).json({ error: 'Method not allowed' });
    return;
  }

  const {
    authInfo,
    sport,
    day,
    usernames,
    contestId: providedContestId,
    contestType = 'sport',
    scanLimit = 300,
  } = req.body || {};

  if (!authInfo || typeof authInfo !== 'string') {
    res.status(400).json({ error: 'authInfo is required' });
    return;
  }
  const normalizedSport = String(sport || '').trim().toLowerCase();
  if (!VALID_SPORTS.includes(normalizedSport)) {
    res.status(400).json({ error: `sport must be one of: ${VALID_SPORTS.join(', ')}` });
    return;
  }
  if (!Array.isArray(usernames) || usernames.length === 0) {
    res.status(400).json({ error: 'usernames must be a non-empty array' });
    return;
  }

  let normalizedDay;
  try {
    normalizedDay = normalizeDay(day);
  } catch (e) {
    res.status(400).json({ error: e.message });
    return;
  }

  const cleanUsernames = [...new Set(usernames.map((u) => String(u).trim()).filter(Boolean))];
  if (cleanUsernames.length === 0) {
    res.status(400).json({ error: 'At least one non-empty username is required' });
    return;
  }

  let contestId;
  try {
    contestId =
      providedContestId ||
      (await findContestId(normalizedSport, normalizedDay, authInfo, contestType, scanLimit));
  } catch (e) {
    res.status(502).json({ error: `Contest lookup failed: ${e.message}` });
    return;
  }

  const summaryRows = [];
  const lineupRows = [];
  const errors = [];

  await mapWithConcurrency(cleanUsernames, 6, async (username) => {
    try {
      const userId = await resolveUserId(username, authInfo);
      const payload = await fetchLineup(contestId, userId, authInfo, contestType);
      const { summary, players } = summarizeLineup(username, payload);
      summaryRows.push(summary);
      lineupRows.push(...players);
    } catch (e) {
      errors.push({ inputUsername: username, error: e.message });
    }
  });

  summaryRows.sort((a, b) => (b.calculatedScore || 0) - (a.calculatedScore || 0));

  res.status(200).json({
    contestId,
    sport: normalizedSport,
    day: normalizedDay,
    summary: summaryRows,
    lineups: lineupRows,
    errors,
  });
};


